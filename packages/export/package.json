{
  "name": "@quar/export",
  "version": "0.1.0",
  "private": true,
  "description": "Export pipeline for Quar Animator (Lottie, video, sprites)",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --tsconfig tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@quar/types": "workspace:*",
    "@quar/core": "workspace:*",
    "@quar/animation": "workspace:*",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
